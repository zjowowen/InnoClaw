#: ../../usage/features.md:1 e9046ce4d5de44d2a32e2d41e7c0760a
msgid "Core Features"
msgstr "核心功能"

#: ../../usage/features.md:3 9f59185771684d6cb8d105c3630ffa37
msgid ""
"InnoClaw provides a rich set of features for AI-powered research and "
"file management."
msgstr "InnoClaw 提供了丰富的 AI 驱动研究和文件管理功能。"

#: ../../usage/features.md:5 d8c916a2fb314c5cabe488ee7de07235
msgid "Workspace Management"
msgstr "工作空间管理"

#: ../../usage/features.md:7 1941e8b1bbd74fbfb0d7c77d2a01cafb
msgid ""
"Workspaces map server-side folders into the application. Each workspace "
"is a persistent container for files, chat history, and notes."
msgstr "工作空间将服务器端文件夹映射到应用程序中。每个工作空间是文件、对话历史和笔记的持久化容器。"

#: ../../usage/features.md:9 499699a4ec3d4491bca3c24d2d22c3a5
msgid ""
"**Create** workspaces from any allowed root directory (configured via "
"`WORKSPACE_ROOTS`)"
msgstr "从任何允许的根目录（通过 `WORKSPACE_ROOTS` 配置）**创建**工作空间"

#: ../../usage/features.md:10 536713e48f9d40c5a75391c6ccce42f5
msgid "**Open** existing workspaces from the home page"
msgstr "从首页**打开**已有的工作空间"

#: ../../usage/features.md:11 856b41bfd21946c28535b424a0c0424d
msgid ""
"**Delete** workspaces (removes only the database record; files on disk "
"are preserved)"
msgstr "**删除**工作空间（仅删除数据库记录；磁盘上的文件会被保留）"

#: ../../usage/features.md:12 5433820fa126488ea774717656fb5e38
msgid "**GitHub Clone** — Clone a GitHub repository directly as a new workspace"
msgstr "**GitHub 克隆** —— 直接将 GitHub 仓库克隆为新的工作空间"

#: ../../usage/features.md:14 b32fc4b68a0e4c15b63dad4c36503027
msgid "File Browser"
msgstr "文件浏览器"

#: ../../usage/features.md:16 3dc26183d4f74492a096173f28b61ed6
msgid "The file browser provides full file management within a workspace:"
msgstr "文件浏览器提供工作空间内的完整文件管理功能："

#: ../../usage/features.md:18 2d15b696e40941fbb1d7d861983498ad
msgid "**Tree View** — Hierarchical directory browsing with expand/collapse"
msgstr "**树形视图** —— 支持展开/折叠的层级目录浏览"

#: ../../usage/features.md:19 9f92370552a04b4db649be64b3e8bef9
msgid "**Upload** — Drag-and-drop or click to upload files"
msgstr "**上传** —— 拖放或点击上传文件"

#: ../../usage/features.md:20 8f3961970b6c45ee9c1cc97256ecfa22
msgid "**Create** — New files and folders"
msgstr "**创建** —— 新建文件和文件夹"

#: ../../usage/features.md:21 b1e0c8a898314380813c7d7fe1e7817c
msgid "**Edit** — Open files in the built-in editor"
msgstr "**编辑** —— 在内置编辑器中打开文件"

#: ../../usage/features.md:22 afe0846b02a145cc86679b4ca1a6d07b
msgid "**Rename / Delete** — Right-click context menu"
msgstr "**重命名 / 删除** —— 右键上下文菜单"

#: ../../usage/features.md:23 c7711c533f0e42f3a3099ff20c84423b
msgid ""
"**Preview** — Preview images, PDFs, 3D models (STL, OBJ, GLTF, etc.), and"
" more"
msgstr "**预览** —— 预览图片、PDF、3D 模型（STL、OBJ、GLTF 等）及更多格式"

#: ../../usage/features.md:24 877109a348764f83b2b89131415207ba
msgid "**Sync** — Trigger RAG indexing to enable AI-powered search"
msgstr "**同步** —— 触发 RAG 索引以启用 AI 搜索"

#: ../../usage/features.md:26 481b63e4678248e58d490f2fba60b009
msgid "RAG Chat"
msgstr "RAG 对话"

#: ../../usage/features.md:28 6f99f2f2c9a04df2beba0c66b53dc476
msgid ""
"The AI chat interface uses Retrieval-Augmented Generation to answer "
"questions based on your workspace files:"
msgstr "AI 对话界面使用检索增强生成技术，基于您的工作空间文件回答问题："

#: ../../usage/features.md:30 3f476665b702482eb03e7b64dc48df1f
msgid "**Sync** your workspace to index files into the vector store"
msgstr "**同步**工作空间以将文件索引到向量存储中"

#: ../../usage/features.md:31 370400e5866e4b72ac93e2c9c8db2eaf
msgid "**Ask questions** in the chat panel"
msgstr "在对话面板中**提问**"

#: ../../usage/features.md:32 dc7ee73a59f146beb1bf643cb710f4bc
msgid ""
"**Receive answers** with `[Source: filename]` citations pointing to the "
"relevant files"
msgstr "**接收回答**，附带 `[Source: filename]` 引用指向相关文件"

#: ../../usage/features.md:33 fdfcab4c00c54352a610411824ab0ba8
msgid "**Multi-turn conversations** — Context is maintained across messages"
msgstr "**多轮对话** —— 上下文在消息之间保持连续"

#: ../../usage/features.md:35 92c52b2b589c4a0297c571c6ae33c09c
msgid "Supported File Types for RAG"
msgstr "RAG 支持的文件类型"

#: ../../usage/features.md:37 b6ac274044194a08ba581f31d8959bc3
msgid "The following file types are supported for text extraction and indexing:"
msgstr "以下文件类型支持文本提取和索引："

