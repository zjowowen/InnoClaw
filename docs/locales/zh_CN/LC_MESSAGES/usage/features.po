msgid "Category"
msgstr "分类"

#: ../../usage/features.md e53532f7884e4411a0f3632036f1b3fb
msgid "Extensions"
msgstr "扩展名"

#: ../../usage/features.md 509ab24de35a4348b959bbb1a761f4e2
msgid "Documents"
msgstr "文档"

#: ../../usage/features.md 9e8c77596e4c43939d89c58debe25811
msgid "`.pdf`, `.txt`, `.md`, `.html`"
msgstr "`.pdf`、`.txt`、`.md`、`.html`"

#: ../../usage/features.md 3fd180551cf04fbab046099ad765d013
msgid "Data"
msgstr "数据"

#: ../../usage/features.md 53a21b81f69543b5aa3a74027f9516f8
msgid "`.json`, `.csv`"
msgstr "`.json`、`.csv`"

#: ../../usage/features.md 49d78c8739534d8bbea68f5d414ce982
msgid "Code"
msgstr "代码"

#: ../../usage/features.md f5a24279a1c548e7b4cdecc4daad16c8
msgid ""
"`.js`, `.ts`, `.py`, `.java`, `.go`, `.rs`, `.cpp`, `.c`, `.rb`, `.php`, "
"and more"
msgstr "`.js`、`.ts`、`.py`、`.java`、`.go`、`.rs`、`.cpp`、`.c`、`.rb`、`.php` 等"

#: ../../usage/features.md:45 ba044bdae75d49f5a559a201d684b146
msgid "Note Generation"
msgstr "笔记生成"

#: ../../usage/features.md:47 b45c96c632234817b7e3844581a1663b
msgid "Automatically generate structured notes from your workspace content:"
msgstr "从工作空间内容自动生成结构化笔记："

