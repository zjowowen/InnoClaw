#: ../../usage/features.md:56 d12daf0ccac84edebb1d2aec8c78e3cf
msgid "Notes can also be created and edited manually."
msgstr "笔记也可以手动创建和编辑。"

#: ../../usage/features.md:58 00057bb2c6504b1993b39a09e63a1cdd
msgid "Agent Mode"
msgstr "Agent 模式"

#: ../../usage/features.md:60 e2efd68834a546b3b542bdc4f45d8b6c
msgid ""
"The Agent mode provides an autonomous AI assistant with access to system "
"tools:"
msgstr "Agent 模式提供一个可访问系统工具的自主 AI 助手："

#: ../../usage/features.md:62 f681bc7d86c741048e17cbf16ec176cc
msgid "**Bash** — Execute shell commands"
msgstr "**Bash** —— 执行 Shell 命令"

#: ../../usage/features.md:63 39361537c7b94cadb7bd2fe99f0f8e75
msgid "**File Operations** — Read, write, and list directory contents"
msgstr "**文件操作** —— 读取、写入和列出目录内容"

#: ../../usage/features.md:64 e11ac746edbd407e8531a90587885cd4
msgid "**Grep** — Search file contents with regular expressions"
msgstr "**Grep** —— 使用正则表达式搜索文件内容"

#: ../../usage/features.md:65 338586ff39b94ea1b1ce67ee9d3259c3
msgid "**kubectl** — Kubernetes cluster management (when configured)"
msgstr "**kubectl** —— Kubernetes 集群管理（配置后可用）"

#: ../../usage/features.md:67 ef574b29969341d3b273b1754a73e08b
msgid ""
"Agent mode is useful for tasks that require interacting with the file "
"system or running commands."
msgstr "Agent 模式适用于需要与文件系统交互或运行命令的任务。"

#: ../../usage/features.md:69 4b1005dee2f94ebba6a956d79c17bb13
msgid "Skills"
msgstr "技能"

#: ../../usage/features.md:71 9baf033d7a84465cbcbbaee157639c0a
msgid "Skills are reusable prompt templates for common tasks:"
msgstr "技能是用于常见任务的可复用提示词模板："

