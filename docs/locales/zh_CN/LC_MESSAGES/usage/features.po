msgid "Type"
msgstr "类型"

#: ../../usage/features.md 7af34985b97346c08a0d465b98847e81
msgid "Description"
msgstr "描述"

#: ../../usage/features.md b9f7d233dfc44a61be4a7ba3bd65fcbb
msgid "**Summary**"
msgstr "**摘要**"

#: ../../usage/features.md effa1ee8ad5342c0835198c8f5a207ac
