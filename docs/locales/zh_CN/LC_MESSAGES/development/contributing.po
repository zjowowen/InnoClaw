msgid "Tests pass (`npm test`)"
msgstr "测试通过（`npm test`）"

#: ../../development/contributing.md:80 792a05abb3d745eb99ea666bdc3a847d
msgid "Lint passes (`npm run lint`)"
msgstr "Lint 通过（`npm run lint`）"

#: ../../development/contributing.md:81 7225b7bfaeb449df99ebeb6cfbb7e814
msgid "Build succeeds (`npm run build`)"
msgstr "构建成功（`npm run build`）"

#: ../../development/contributing.md:82 8bb9dd4f9f9a4a7b97709ff1506199ef
msgid "Documentation updated (if applicable)"
msgstr "文档已更新（如适用）"

