#: ../../getting-started/installation.md:1 7e55ff6f9fec49299cd40309331ff355
msgid "Installation"
msgstr "安装"

#: ../../getting-started/installation.md:3 403fb892175a49fa9136a58ccd04035f
msgid ""
"This guide walks you through setting up InnoClaw locally for "
"development or self-hosting."
msgstr "本指南将引导您在本地搭建 InnoClaw，用于开发或自托管。"

#: ../../getting-started/installation.md:5 6a52d44d3c0346f3b900d0e2fb0aa90b
msgid "Prerequisites"
msgstr "前置要求"

#: ../../getting-started/installation.md:7 28f81859b1ce4ecfac5a2b4bc93efa77
msgid "Before you begin, ensure you have the following installed:"
msgstr "在开始之前，请确保已安装以下软件："

#: ../../getting-started/installation.md 1d50a9414eb24c6d9cda8153c715ca53
#: 849274ed7256480ca5163bb0be5cb8f8
msgid "Requirement"
msgstr "要求"

#: ../../getting-started/installation.md 1c1e8a07b3a1446aa5ba67d32511759e
msgid "Version"
msgstr "版本"

#: ../../getting-started/installation.md 0a79abe5dc834e0a9a5a98a949fbb05f
#: 29feaa8c7d4a48aaa754bd36f2c6f150
msgid "Notes"
msgstr "备注"

#: ../../getting-started/installation.md ffc4383698fb40ffa0fa78734791cb22
