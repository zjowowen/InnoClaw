# ── InnoClaw Docker Environment ──────────────────────────────────
# Copy this file to .env.production.local and fill in your values:
#   cp .env.production.example .env.production.local

# [Required] Workspace root directories (comma-separated paths INSIDE the container)
# These must match the volume mounts in docker-compose.yml.
# Default compose mount maps HOST_WORKSPACE_PATH → /research
WORKSPACE_ROOTS=/research

# [Optional] SQLite database path (default: ./data/innoclaw.db, persisted via Docker volume)
# DATABASE_URL=./data/innoclaw.db

# ── AI API Keys (at least one required) ──────────────────────────
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...

# ── Custom API Base URLs (optional, for proxies) ─────────────────
# OPENAI_BASE_URL=https://api.your-provider.com/v1
# ANTHROPIC_BASE_URL=https://api.your-provider.com
# GEMINI_BASE_URL=https://api.your-provider.com

# ── Embedding (optional, falls back to OPENAI_API_KEY) ───────────
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_BASE_URL=https://api.your-provider.com/v1
# EMBEDDING_MODEL=text-embedding-3-small

# ── Default LLM (overridable in Settings UI) ─────────────────────
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o

# ── Agent settings ────────────────────────────────────────────────
# AGENT_MAX_STEPS=10

# ── GitHub (optional, for private repo cloning) ──────────────────
# GITHUB_TOKEN=ghp_...

# ── HuggingFace (optional) ───────────────────────────────────────
# HF_TOKEN=hf_...
# HF_DATASETS_PATH=./data/hf-datasets
# HF_MIRROR=https://hf-mirror.com

# ── HTTP Proxy (optional) ────────────────────────────────────────
# HTTP_PROXY=http://your-proxy:3128
# HTTPS_PROXY=http://your-proxy:3128
# NO_PROXY=localhost,127.0.0.1

# ── Feishu Bot (optional) ────────────────────────────────────────
# FEISHU_BOT_ENABLED=true
# FEISHU_APP_ID=cli_xxxx
# FEISHU_APP_SECRET=xxxx
# FEISHU_VERIFICATION_TOKEN=xxxx
# FEISHU_ENCRYPT_KEY=xxxx
# FEISHU_PUSH_SECRET=xxxx

# ── Additional providers (optional) ──────────────────────────────
# SHLAB_API_KEY=...
# QWEN_API_KEY=...
# MOONSHOT_API_KEY=...
# DEEPSEEK_API_KEY=...
# MINIMAX_API_KEY=...
# ZHIPU_API_KEY=...
